#!/usr/bin/env bash
set -Eeuo pipefail
trap 'echo "[Openbox-Init] ERROR at line $LINENO"; exit 1' ERR

USER_NAME="${USERNAME:-hyper}"
HOME_DIR="$(getent passwd "$USER_NAME" | cut -d: -f6 || true)"

[[ -n "$HOME_DIR" && -d "$HOME_DIR" ]] || {
  echo "[Openbox-Init] Invalid user or home directory: $USER_NAME"
  exit 1
}

CONFIG_DIR="$HOME_DIR/.config/openbox"
TARGET_FILE="$CONFIG_DIR/autostart"
SOURCE_FILE="/etc/xdg/openbox/autostart"

log() {
  printf '%s [Openbox-Init] %s\n' "$(date '+%H:%M:%S')" "$*"
}

# Ensure source exists
[[ -f "$SOURCE_FILE" ]] || {
  log "Missing system autostart template → $SOURCE_FILE"
  exit 1
}

# Create config dir safely
if [[ ! -d "$CONFIG_DIR" ]]; then
  log "Creating Openbox config directory..."
  install -d -m 0755 -o "$USER_NAME" -g "$USER_NAME" "$CONFIG_DIR"
fi

# Deploy autostart if missing
if [[ ! -f "$TARGET_FILE" ]]; then
  log "Deploying default Openbox autostart..."
  install -m 0644 "$SOURCE_FILE" "$TARGET_FILE"
  chown "$USER_NAME:$USER_NAME" "$TARGET_FILE"
else
  log "Autostart already exists → skipping"
fi

log "Completed."
