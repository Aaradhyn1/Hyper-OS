#!/usr/bin/env bash
set -Eeuo pipefail

failures=0

check_cmd() {
  local name="$1"; shift
  if "$@" >/dev/null 2>&1; then
    printf '[PASS] %s\n' "$name"
  else
    printf '[FAIL] %s\n' "$name"
    failures=$((failures + 1))
  fi
}

check_cmd "Vulkan loader" vulkaninfo --summary
check_cmd "Wine binary" wine --version
check_cmd "Winetricks binary" winetricks --version
check_cmd "GameMode binary" gamemoderun --version
check_cmd "MangoHud binary" mangohud --version
check_cmd "Steam runtime" steam --version

if [[ -d /usr/share/steam/compatibilitytools.d ]]; then
  printf '[INFO] Proton custom tools path exists: /usr/share/steam/compatibilitytools.d\n'
else
  printf '[WARN] Proton custom tools path not found: /usr/share/steam/compatibilitytools.d\n'
fi

if [[ "$failures" -gt 0 ]]; then
  printf '[ERROR] %d validation checks failed.\n' "$failures" >&2
  exit 1
fi

printf '[OK] HyperOS gaming validation completed successfully.\n'
