<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <theme>
    <name>Clearlooks</name>
    <titleLayout>NLIMC</titleLayout>
    <font place="ActiveWindow"><name>DejaVu Sans</name><size>10</size><weight>bold</weight></font>
    <font place="MenuHeader"><name>DejaVu Sans</name><size>10</size><weight>bold</weight></font>
    <font place="MenuItem"><name>DejaVu Sans</name><size>10</size><weight>normal</weight></font>
  </theme>
  <desktops><number>1</number><firstdesk>1</firstdesk><names><name>Hyper</name></names></desktops>
  <resistance><strength>10</strength><screen_edge_strength>20</screen_edge_strength></resistance>
</openbox_config>
