pkgname=hyperos-config
pkgver=1.0.0
pkgrel=1
pkgdesc='Hyper OS baseline system configuration'
arch=('any')
url='https://github.com/hyper-os'
license=('custom')
depends=('bash' 'systemd' 'networkmanager')
backup=(
  'etc/skel/.bashrc'
  'etc/sysctl.d/99-hyperos.conf'
  'etc/systemd/system.conf.d/10-hyperos.conf'
  'etc/NetworkManager/conf.d/10-hyperos.conf'
)
source=(
  'files/etc/skel/.bashrc'
  'files/etc/sysctl.d/99-hyperos.conf'
  'files/etc/systemd/system.conf.d/10-hyperos.conf'
  'files/etc/NetworkManager/conf.d/10-hyperos.conf'
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
  cd "$srcdir/files"
  cp -a etc "$pkgdir/"
  install -d "$pkgdir/usr/share/licenses/$pkgname"
  cat > "$pkgdir/usr/share/licenses/$pkgname/LICENSE" <<'LIC'
Hyper OS system configuration assets.
LIC
}
