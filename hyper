#!/usr/bin/env bash
set -Eeuo pipefail

# =========================
# Environment
# =========================
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/hyper-$(date +%Y%m%d-%H%M%S).log"
LOCK_FILE="/tmp/hyper-build.lock"

DRY_RUN=0
DEBUG=0
STEP_TIMEOUT="${STEP_TIMEOUT:-0}"

mkdir -p "$LOG_DIR"

# =========================
# Logging
# =========================
log() {
  local level="$1"; shift
  local color="\e[34m"
  [[ "$level" == "ERROR" ]] && color="\e[31m"
  [[ "$level" == "SUCCESS" ]] && color="\e[32m"
  [[ "$level" == "WARN" ]] && color="\e[33m"

  printf "${color}[hyper][%s][%s] %s\e[0m\n" \
    "$level" "$(date '+%H:%M:%S')" "$*" | tee -a "$LOG_FILE"
}

die() {
  log ERROR "$*"
  exit 1
}

# =========================
# Cleanup & Signals
# =========================
cleanup() {
  log INFO "Cleanup triggered"
  [[ -f "$LOCK_FILE" ]] && rm -f "$LOCK_FILE"
}
trap cleanup EXIT INT TERM

acquire_lock() {
  exec 200>"$LOCK_FILE"
  flock -n 200 || die "Another build is running"
}

# =========================
# Validation
# =========================
require_tool() {
  for tool in "$@"; do
    command -v "$tool" >/dev/null 2>&1 || die "Missing: $tool"
  done
}

check_disk() {
  local avail
  avail=$(df --output=avail "$ROOT_DIR" | tail -n1)
  [[ "$avail" -gt 1048576 ]] || die "Insufficient disk space (<1GB)"
}

# =========================
# Execution Engine
# =========================
run_step() {
  local label="$1"; shift
  local script="$1"; shift

  [[ -x "$script" ]] || die "Missing script: $script"

  log INFO "===> $label"
  local start_time
  start_time=$(date +%s)

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log WARN "[DRY-RUN] $script"
    return 0
  fi

  set +e

  if [[ "$STEP_TIMEOUT" -gt 0 ]]; then
    timeout --kill-after=5 "$STEP_TIMEOUT" \
      bash "$script" "$@" 2>&1 | tee -a "$LOG_FILE"
  else
    bash "$script" "$@" 2>&1 | tee -a "$LOG_FILE"
  fi

  local status=${PIPESTATUS[0]}
  set -e

  local duration=$(( $(date +%s) - start_time ))

  [[ $status -eq 0 ]] \
    && log SUCCESS "$label completed in ${duration}s" \
    || die "$label failed (${duration}s, exit=$status)"
}

# =========================
# Targets
# =========================
build_iso() {
  require_tool mksquashfs grub-mkrescue xorriso
  run_step "RootFS Build" "$ROOT_DIR/scripts/build-rootfs.sh" "$@"
  run_step "System Config" "$ROOT_DIR/scripts/configure-system.sh" "$@"
  run_step "ISO Build" "$ROOT_DIR/scripts/build-iso.sh" "$@"
}

build_rpi() {
  require_tool make gcc bison flex
  run_step "Buildroot Pipeline" "$ROOT_DIR/scripts/build.sh" "$@"
}

build_fedora() {
  run_step "Fedora KDE Build" "$ROOT_DIR/scripts/build-fedora-kde.sh" "$@"
}

# =========================
# CLI
# =========================
usage() {
  cat <<EOF
Hyper OS CLI

Usage:
  $0 build <target> [options]

Targets:
  iso
  rpi
  fedora

Options:
  --debug
  --dry-run
  --timeout=N
EOF
}

main() {
  [[ $# -lt 2 ]] && { usage; exit 2; }

  local action="$1"; shift
  local target="$1"; shift

  for arg in "$@"; do
    case "$arg" in
      --debug) DEBUG=1; set -x ;;
      --dry-run) DRY_RUN=1 ;;
      --timeout=*) STEP_TIMEOUT="${arg#*=}" ;;
      *) ;;
    esac
  done

  acquire_lock
  check_disk

  case "$action" in
    build)
      case "$target" in
        iso) build_iso "$@" ;;
        rpi) build_rpi "$@" ;;
        fedora) build_fedora "$@" ;;
        *) die "Unknown target: $target" ;;
      esac
      ;;
    *)
      die "Unknown action: $action"
      ;;
  esac

  log SUCCESS "Pipeline complete"
}

main "$@"
