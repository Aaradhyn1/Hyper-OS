#!/usr/bin/env bash

# ==============================================================================
# Hyper OS Advanced Build System
# ==============================================================================
# Set strict mode:
# -E: Traps inherit from shell functions
# -u: Error on unset variables
# -o pipefail: Pipeline returns status of last command to fail
set -Eeuo pipefail

# --- Environment Setup ---
readonly APP_NAME="hyper"
readonly VERSION="2.0.0"
readonly ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SCRIPTS_DIR="$ROOT_DIR/scripts"
readonly LOG_DIR="$ROOT_DIR/logs/$(date +%Y-%m-%d)"
readonly LOCK_FILE="/tmp/${APP_NAME}.lock"

# --- State Variables ---
VERBOSE=0
DRY_RUN=0
PARALLEL=0
STEP_TIMEOUT="${STEP_TIMEOUT:-0}"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)

# --- Visuals ---
readonly CLR_RESET="\e[0m"
readonly CLR_BLU="\e[1;34m"
readonly CLR_GRN="\e[1;32m"
readonly CLR_RED="\e[1;31m"
readonly CLR_YLW="\e[1;33m"
readonly CLR_MAG="\e[1;35m"

# =========================
# Core Utilities
# =========================

mkdir -p "$LOG_DIR"

log() {
    local level="$1"; shift
    local color="$CLR_BLU"
    case "$level" in
        ERROR)   color="$CLR_RED" ;;
        SUCCESS) color="$CLR_GRN" ;;
        WARN)    color="$CLR_YLW" ;;
        INFO)    color="$CLR_MAG" ;;
    esac

    printf "${color}[%-7s] [%s] %s${CLR_RESET}\n" \
        "$level" "$(date '+%H:%M:%S')" "$*" | tee -a "$LOG_DIR/${TIMESTAMP}.log"
}

die() {
    log ERROR "$*"
    exit 1
}

# --- Signal Handling & Locks ---
cleanup() {
    local exit_code=$?
    [[ -f "$LOCK_FILE" ]] && rm -f "$LOCK_FILE"
    
    if (( exit_code != 0 )); then
        log ERROR "Pipeline aborted prematurely (Exit: $exit_code)"
    fi
}
trap cleanup EXIT INT TERM

acquire_lock() {
    # File descriptor 200 used for the lock
    exec 200>"$LOCK_FILE"
    flock -n 200 || die "Active instance detected. Use 'flock' to manage concurrent builds."
}

# =========================
# Advanced Logic
# =========================

check_requirements() {
    local deps=("df" "tee" "timeout" "bash" "flock")
    
    # Target-specific dependencies
    case "${1:-}" in
        iso)    deps+=("mksquashfs" "grub-mkrescue" "xorriso") ;;
        rpi)    deps+=("make" "gcc" "bison" "flex") ;;
        fedora) deps+=("dnf" "mock") ;;
    esac

    for tool in "${deps[@]}"; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            log WARN "Missing tool: $tool. Attempting to proceed, but expect failure."
        fi
    done
}

# Profiling wrapper
measure_resources() {
    # Simple background monitor for CPU/RAM peak (Advanced version would use 'ps' or 'cgexec')
    # For now, we just record duration and disk delta
    local start_disk
    start_disk=$(df --output=used "$ROOT_DIR" | tail -n1)
    echo "$start_disk"
}

# =========================
# Execution Engine
# =========================

run_step() {
    local label="$1"; shift
    local script="$SCRIPTS_DIR/$1"; shift
    local log_out="$LOG_DIR/step-${label// /-}.log"

    [[ -f "$script" ]] || die "Script not found: $script"
    
    log INFO "Starting: $label"
    local start_time=$SECONDS

    if [[ "$DRY_RUN" -eq 1 ]]; then
        log WARN "[DRY-RUN] Would execute: $script $*"
        return 0
    fi

    # Subshell execution to isolate environment
    (
        set +e
        if [[ "$STEP_TIMEOUT" -gt 0 ]]; then
            timeout --kill-after=10s "$STEP_TIMEOUT" bash "$script" "$@"
        else
            bash "$script" "$@"
        fi
    ) >> "$log_out" 2>&1

    local status=$?
    local duration=$(( SECONDS - start_time ))

    if [[ $status -eq 0 ]]; then
        log SUCCESS "$label (Time: ${duration}s) | Log: $log_out"
    else
        log ERROR "$label FAILED (Exit: $status). See $log_out for details."
        # Print last 10 lines of the log for immediate context
        tail -n 10 "$log_out"
        exit 1
    fi
}

# =========================
# Build Targets
# =========================

build_iso() {
    log INFO "Initializing ISO Build Pipeline"
    run_step "RootFS Generation" "build-rootfs.sh" "$@"
    run_step "System Hardening" "configure-system.sh" "$@"
    run_step "Image Mastering"  "build-iso.sh" "$@"
}

build_rpi() {
    log INFO "Initializing Raspberry Pi Image Build"
    run_step "Kernel Compilation" "build.sh" "--arch=arm64" "$@"
}

# =========================
# Main Entry
# =========================

usage() {
    cat <<EOF
${CLR_BLU}Hyper OS Build Engine v${VERSION}${CLR_RESET}

${CLR_YLW}Usage:${CLR_RESET}
  $0 <action> <target> [options]

${CLR_YLW}Actions:${CLR_RESET}
  build       Execute build pipeline

${CLR_YLW}Targets:${CLR_RESET}
  iso         Generate standard x86_64 ISO
  rpi         Generate Raspberry Pi ARM image
  fedora      Generate Fedora-based KDE Spin

${CLR_YLW}Options:${CLR_RESET}
  --debug     Enable trace mode (set -x)
  --dry-run   Show what would happen without executing
  --timeout=N Max seconds per step (default: 0)
  --parallel  Enable parallel step execution (where supported)

EOF
}

main() {
    [[ $# -lt 2 ]] && { usage; exit 2; }

    local action="$1"; shift
    local target="$1"; shift

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --debug)   VERBOSE=1; set -x ;;
            --dry-run) DRY_RUN=1 ;;
            --timeout=*) STEP_TIMEOUT="${1#*=}" ;;
            --parallel) PARALLEL=1 ;;
            *) break ;; # Pass remaining args to scripts
        esac
        shift
    done

    acquire_lock
    check_requirements "$target"
    
    # Pre-flight check
    local avail
    avail=$(df --output=avail "$ROOT_DIR" | tail -n1)
    (( avail < 2097152 )) && log WARN "Low disk space (<2GB). Build might fail."

    case "$action" in
        build)
            case "$target" in
                iso)    build_iso "$@" ;;
                rpi)    build_rpi "$@" ;;
                *)      die "Target '$target' not implemented." ;;
            esac
            ;;
        *)
            die "Invalid action: $action"
            ;;
    esac

    log SUCCESS "All stages finished successfully. Logs available in $LOG_DIR"
}

main "$@"
