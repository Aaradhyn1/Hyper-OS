#!/usr/bin/env bash
set -Eeuo pipefail

# =========================
# Environment
# =========================
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/hyper-$(date +%Y%m).log"
LOCK_FILE="/tmp/hyper-build.lock"

DRY_RUN=0
DEBUG=0
STEP_TIMEOUT="${STEP_TIMEOUT:-0}"  # seconds (0 = no timeout)

mkdir -p "$LOG_DIR"

# =========================
# Logging
# =========================
log() {
  local level="$1"; shift
  local color="\e[34m"
  [[ "$level" == "ERROR" ]] && color="\e[31m"
  [[ "$level" == "SUCCESS" ]] && color="\e[32m"

  printf "${color}[hyper][%s][%s] %s\e[0m\n" \
    "$level" "$(date '+%H:%M:%S')" "$*" | tee -a "$LOG_FILE"
}

die() {
  log ERROR "$*"
  exit 1
}

# =========================
# Cleanup & Lock
# =========================
cleanup() {
  log INFO "Releasing lock and cleaning up..."
  flock -u 200 || true
  rm -f "$LOCK_FILE"
}
trap cleanup EXIT

acquire_lock() {
  exec 200>"$LOCK_FILE"
  flock -n 200 || die "Another build is running."
}

# =========================
# Validation
# =========================
require_tool() {
  for tool in "$@"; do
    command -v "$tool" >/dev/null 2>&1 || die "Missing dependency: $tool"
  done
}

check_disk() {
  local avail
  avail=$(df "$ROOT_DIR" | awk 'NR==2 {print $4}')
  [[ "$avail" -gt 1048576 ]] || die "Not enough disk space."
}

# =========================
# Execution Engine
# =========================
run_step() {
  local label="$1"; shift
  local script="$1"; shift

  [[ -x "$script" ]] || die "Script missing: $script"

  log INFO "===> $label"

  [[ "$DRY_RUN" -eq 1 ]] && {
    log INFO "[DRY-RUN] Skipping execution: $script"
    return 0
  }

  set +e

  if [[ "$STEP_TIMEOUT" -gt 0 ]]; then
    timeout "$STEP_TIMEOUT" bash "$script" "$@" 2>&1 | tee -a "$LOG_FILE"
  else
    bash "$script" "$@" 2>&1 | tee -a "$LOG_FILE"
  fi

  local status=${PIPESTATUS[0]}
  set -e

  [[ $status -eq 0 ]] || die "Step '$label' failed (exit $status)"
}

# =========================
# Targets
# =========================
build_iso() {
  require_tool mksquashfs grub-mkrescue xorriso
  run_step "Rootfs"   "$ROOT_DIR/scripts/build-rootfs.sh" "$@"
  run_step "Config"   "$ROOT_DIR/scripts/configure-system.sh" "$@"
  run_step "ISO"      "$ROOT_DIR/scripts/build-iso.sh" "$@"
  log SUCCESS "ISO Build Complete"
}

build_rpi() {
  require_tool make gcc bison flex
  run_step "Buildroot" "$ROOT_DIR/scripts/build.sh" "$@"
  log SUCCESS "Raspberry Pi Image Complete"
}

# =========================
# CLI
# =========================
usage() {
  cat <<EOF
Hyper OS CLI

Usage:
  $0 build <target> [options]

Targets:
  iso
  rpi
  fedora

Options:
  --debug       Enable shell tracing
  --dry-run     Simulate execution
  --timeout=N   Timeout per step (seconds)
EOF
}

main() {
  [[ $# -lt 2 ]] && { usage; exit 1; }

  local action="$1"; shift
  local target="$1"; shift

  for arg in "$@"; do
    case "$arg" in
      --debug) DEBUG=1; set -x ;;
      --dry-run) DRY_RUN=1 ;;
      --timeout=*) STEP_TIMEOUT="${arg#*=}" ;;
    esac
  done

  acquire_lock
  check_disk

  case "$action" in
    build)
      case "$target" in
        iso) build_iso "$@" ;;
        rpi) build_rpi "$@" ;;
        fedora) run_step "Fedora" "$ROOT_DIR/scripts/build-fedora-kde.sh" "$@" ;;
        *) die "Unknown target: $target" ;;
      esac
      ;;
    *)
      die "Unknown action: $action"
      ;;
  esac
}

main "$@"
