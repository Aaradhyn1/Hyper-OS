#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<USAGE
Usage:
  ./hyper build iso [extra-args]
  ./hyper build rpi [extra-args]
  ./hyper build fedora [extra-args]
USAGE
}

die() {
  echo "[hyper] ERROR: $*" >&2
  exit 1
}

require_tool() {
  local tool="$1"
  command -v "$tool" >/dev/null || die "$tool not found"
}

run_step() {
  local step="$1"
  shift
  echo "[hyper] Running: $step"
  "$@"
}

main() {
  [[ $# -ge 2 ]] || {
    usage
    die "Missing required arguments"
  }

  local action="$1"
  local target="$2"
  shift 2

  case "$action" in
    build) ;;
    *)
      usage
      die "Unknown action: $action"
      ;;
  esac

  case "$target" in
    iso)
      require_tool mksquashfs
      require_tool grub-mkrescue
      require_tool unsquashfs
      run_step "build-rootfs" "$ROOT_DIR/scripts/build-rootfs.sh" "$@"
      run_step "configure-system" "$ROOT_DIR/scripts/configure-system.sh" "$@"
      run_step "build-iso" "$ROOT_DIR/scripts/build-iso.sh" "$@"
      ;;
    rpi)
      require_tool make
      if [[ "${OFFLINE_FALLBACK:-1}" != "1" && ! -f "${BUILDROOT_DIR:-$ROOT_DIR/buildroot}/Makefile" ]]; then
        die "Buildroot source not found and OFFLINE_FALLBACK is disabled"
      fi
      run_step "build-rpi" "$ROOT_DIR/scripts/build.sh" "$@"
      ;;
    fedora)
      if [[ "${OFFLINE_FALLBACK:-1}" != "1" ]]; then
        require_tool livemedia-creator
      fi
      run_step "build-fedora" "$ROOT_DIR/scripts/build-fedora-kde.sh" "$@"
      ;;
    *)
      usage
      die "Unknown build target: $target"
      ;;
  esac
}

main "$@"
